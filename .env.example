# ComandaFlow SaaS - Docker Configuration
# Copy this file to .env and modify as needed

# ===========================================
# DOCKER PORTS CONFIGURATION
# ===========================================

# Application Ports
WEB_PORT=8081                    # Puerto para la aplicación web (nginx) - HTTP
WEB_HTTPS_PORT=8443             # Puerto para la aplicación web (nginx) - HTTPS
POSTGRES_PORT=5433              # Puerto para PostgreSQL
PGADMIN_PORT=8082               # Puerto para PgAdmin
MAILHOG_SMTP_PORT=1025          # Puerto SMTP para MailHog
MAILHOG_WEB_PORT=8025           # Puerto web para MailHog

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

DB_NAME=commandaflow_saas
DB_USER=postgres
DB_PASS=secret

# PgAdmin Configuration
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASS=secret

# ===========================================
# APPLICATION ENVIRONMENT
# ===========================================

APP_ENV=local
APP_DEBUG=true
