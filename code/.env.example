# ComandaFlow SaaS - Laravel Application Configuration
# Copy this file to .env and modify as needed

# ===========================================
# LARAVEL CORE CONFIGURATION
# ===========================================

APP_NAME="ComandaFlow SaaS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8081

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ===========================================
# LOGGING CONFIGURATION
# ===========================================

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=commandaflow_saas
DB_USERNAME=postgres
DB_PASSWORD=secret

# ===========================================
# SESSION CONFIGURATION
# ===========================================

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ===========================================
# CACHE & QUEUE CONFIGURATION
# ===========================================

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===========================================
# MAIL CONFIGURATION
# ===========================================

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@comandaflow.com"
MAIL_FROM_NAME="${APP_NAME}"

# ===========================================
# AWS CONFIGURATION
# ===========================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ===========================================
# VITE CONFIGURATION
# ===========================================

VITE_APP_NAME="${APP_NAME}"

# ===========================================
# MULTI-TENANCY CONFIGURATION
# ===========================================

CENTRAL_DOMAIN=comandaflow.local
TENANT_DOMAIN_SUFFIX=comandaflow.local

# ===========================================
# TIME TRACKER CONFIGURATION
# ===========================================

TIME_TRACKER_TIMEZONE=America/Mexico_City
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=pakodiazdev/comandaflow-saas
GITHUB_PROJECT_NUMBER=6
GITHUB_PROJECT_ID=your_project_id_here
GITHUB_PROJECT_STATUS_FIELD_ID=your_status_field_id_here
TIME_TRACKER_WAITING=your_waiting_option_id
TIME_TRACKER_IN_PROGRESS=your_in_progress_option_id
TIME_TRACKER_COMPLETE=your_complete_option_id
